{
  "name": "reactoradar",
  "productName": "ReactoRadar",
  "version": "1.6.9",
  "description": "macOS debugger for React Native — Console, Sources, Network, Performance, Memory, Redux, AsyncStorage, React tree. Supports RN 0.74+ with Hermes and New Architecture.",
  "main": "main.js",
  "bin": {
    "reactoradar": "./bin/cli.js",
    "rn-debugger-app": "./bin/cli.js",
    "rn-debugger-setup": "./bin/setup.js"
  },
  "keywords": [
    "react-native",
    "debugger",
    "devtools",
    "electron",
    "redux",
    "network-inspector",
    "hermes",
    "flipper-alternative",
    "reactoradar",
    "macos"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sharanagouda/reactoradar.git"
  },
  "homepage": "https://github.com/sharanagouda/reactoradar#readme",
  "bugs": {
    "url": "https://github.com/sharanagouda/reactoradar/issues"
  },
  "license": "MIT",
  "author": "sharanagouda",
  "files": [
    "main.js",
    "preload.js",
    "index.html",
    "app.js",
    "init.js",
    "panels/",
    "styles.css",
    "sdk/",
    "bin/",
    "assets/",
    "AGENTS.md"
  ],
  "scripts": {
    "start": "unset ELECTRON_RUN_AS_NODE && electron .",
    "setup": "node bin/setup.js",
    "unsetup": "node bin/setup.js --uninstall",
    "build": "electron-builder --mac",
    "pack": "electron-builder --mac --dir"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react-devtools-core": "^5.3.1",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^24.13.0",
    "electron-devtools-installer": "^3.2.0"
  },
  "build": {
    "appId": "com.reactoradar.app",
    "productName": "ReactoRadar",
    "publish": [
      {
        "provider": "github",
        "owner": "sharanagouda",
        "repo": "reactoradar"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "ReactoRadar.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "directories": {
      "output": "dist"
    }
  }
}
